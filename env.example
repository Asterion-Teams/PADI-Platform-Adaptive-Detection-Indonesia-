# ============================================================
# SmartTraffic AI — PADI (Environment Variables Template)
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control!
# ============================================================

# ── Database ────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=Mm2100_mmid                    # Password PostgreSQL lokal
PG_DATABASE=padi_traffic

# ── Security ────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-48-char-secret-string   # ⚠️ Wajib ganti di production!
DEMO_MODE=0                              # 1=enable demo bypass, 0=disable

# ── Admin Credentials ───────────────────────────────────────
# Option A: Set plain password (will be hashed at runtime)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=YourSecureAdminPassword123
OPERATOR_USERNAME=operator
OPERATOR_PASSWORD=YourSecureOperatorPassword456

# Option B: Set pre-hashed password (more secure for production)
# ADMIN_PASSWORD_HASH=<sha256 hash of password>
# OPERATOR_PASSWORD_HASH=<sha256 hash of password>

# Display names (optional)
ADMIN_DISPLAY_NAME=Administrator
OPERATOR_DISPLAY_NAME=Operator

# ── AI Provider ─────────────────────────────────────────────
AI_PROVIDER=ollama                       # ollama | openai | gemini | deepseek | groq
AI_BASE_URL=http://localhost:11434
AI_API_KEY=                             # Kosongkan jika pakai Ollama lokal
AI_MODEL=llama3.2:3b
AI_CHAT_MODEL=qwen2.5:3b
AI_USE_FOR_ANPR=1
AI_USE_FOR_CHAT=1
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# ── Busway Detection Tuning ─────────────────────────────────
BUSWAY_FAST_MIN_SECONDS=3.0             # Kendaraan cepat (>40px/s) dalam busway
BUSWAY_MEDIUM_MIN_SECONDS=5.0           # Kendaraan sedang (20-40px/s)
BUSWAY_SLOW_MIN_SECONDS=8.0             # Kendaraan diam/sangat lambat (<20px/s)
BUSWAY_MIN_ZONE_HITS=3                  # Minimal detection consecutive
BUSWAY_FAST_SPEED_PX_S=40.0             # Batas kecepatan "cepat" (px/s)
BUSWAY_MIN_TRAVEL_DIST_PX=40.0          # Minimal jarak tempuh untuk trigger

# ── Flask ─────────────────────────────────────────────────
FLASK_ENV=development                   # development | production
HOST_IP=0.0.0.0
HOST_PORT=5000

# ── Social Media (Optional) ─────────────────────────────────
TWITTER_BEARER_TOKEN=                  # Twitter API v2 Bearer Token
TWITTER_SEARCH_QUERY=lalu lintas jakarta
TWITTER_MAX_RESULTS=10
X_SEARCH_QUERY=lalu lintas jakarta site:x.com
X_COOKIES_FILE=data/x_cookies.json
