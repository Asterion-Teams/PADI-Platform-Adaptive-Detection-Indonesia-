{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "outDir": "./app/static/js",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": "./app/static/ts"
  },
  "include": ["app/static/ts/**/*"]
}
